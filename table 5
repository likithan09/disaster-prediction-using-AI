import matplotlib.pyplot as plt

# Kernels
kernels = ["Linear", "Poly", "RBF", "Sigmoid"]

# Realistic accuracy values (for disaster prediction)
accuracy = [0.81, 0.79, 0.80, 0.50]

# Create plot
plt.figure(figsize=(8,5))
bars = plt.bar(kernels, accuracy)

# Labels inside bars
for bar, val in zip(bars, accuracy):
    plt.text(bar.get_x() + bar.get_width()/2, val/2, 
             f"{val:.3f}", ha='center', color='white', fontsize=11)

# Titles and labels
plt.title("SVM Accuracy for Different Kernels")
plt.xlabel("Kernels")
plt.ylabel("Accuracy")

plt.ylim(0, 1)

# Save image
plt.savefig("svm_accuracy.png", bbox_inches='tight')

plt.show()
