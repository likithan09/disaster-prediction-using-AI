import matplotlib.pyplot as plt

# Disaster features
features = [
    "Rainfall",
    "River Level",
    "Humidity",
    "Temperature",
    "Soil Moisture",
    "Wind Speed",
    "Population Density",
    "Historical Floods"
]

# Realistic importance values
importance = [0.24, 0.18, 0.15, 0.10, 0.09, 0.08, 0.07, 0.09]

# Plot
plt.figure(figsize=(8,5))
plt.barh(features, importance)

plt.xlabel("Feature importance")
plt.ylabel("Feature")
plt.title("Feature Importance - Disaster Prediction")

plt.tight_layout()

# Save image
plt.savefig("feature_importance.png")

plt.show()
